{
    "id": "org.kde.kcolorchooser",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kcolorchooser",
    "rename-icon": "kcolorchooser",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland"
    ],
    "modules": [
        {
            "name": "kcolorchooser",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.1/src/kcolorchooser-26.04.1.tar.xz",
                    "sha256": "255cfea23b4825377d730eca7b715b0265df8ea1da739367b3ac0c54effb484e",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kcolorchooser-$version.tar.xz"
                    }
                }
            ],
            "post-install": [
                "install -D /usr/share/icons/breeze/apps/48/kcolorchooser.svg -t /app/share/icons/hicolor/scalable/apps/",
                "desktop-file-edit --set-icon=${FLATPAK_ID} ${FLATPAK_DEST}/share/applications/${FLATPAK_ID}.desktop"
            ]
        }
    ]
}
